# Backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI assistant is optional and OFF by default.
#   none          -> AI endpoints return a disabled response (deterministic analyzer still works fully)
#   deterministic -> built-in, no API key, template-based summaries and remediation
# Model-backed providers (openai/anthropic) can be wired into app/ai/providers.py later.
AI_PROVIDER=none

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
